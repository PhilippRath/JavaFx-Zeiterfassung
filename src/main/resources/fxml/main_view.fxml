<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.zeiterfassung.controller.MainController">
    <!-- Menüleiste oben -->
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu text="Datei">
                    <items>
                        <MenuItem onAction="#onClose" text="Beenden" />
                    </items>
                </Menu>
                <Menu text="Hilfe">
                    <items>
                        <MenuItem onAction="#onAbout" text="Über Zeiterfassung Pro" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    
    <!-- Linker Bereich: Eingabeformular -->
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #dcdcdc; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Neuer Zeiteintrag">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" prefWidth="80.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="150.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Datum:" />
                        <DatePicker fx:id="datePicker" prefWidth="150.0" GridPane.columnIndex="1" />
                        
                        <Label text="Startzeit:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtStartzeit" promptText="z.B. 08:00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Endzeit:" GridPane.rowIndex="2" />
                        <TextField fx:id="txtEndzeit" promptText="z.B. 16:30" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Beschreibung:" GridPane.rowIndex="3" />
                        <TextField fx:id="txtBeschreibung" promptText="z.B. Projektmeeting" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
                
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnLoeschen" mnemonicParsing="false" onAction="#onDelete" text="Löschen" style="-fx-text-fill: red;" />
                        <Button fx:id="btnSpeichern" mnemonicParsing="false" onAction="#onSpeichern" text="Buchen" prefWidth="90.0" />
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
                
                <!-- Status/Feedback Label -->
                <Label fx:id="lblStatus" wrapText="true" textFill="#555555">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>
    </left>
    
    <!-- Mittlerer Bereich: Tabelle aller Zeiteinträge -->
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Gebuchte Arbeitszeiten">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <TableView fx:id="tblEintraege" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDatum" prefWidth="100.0" text="Datum" />
                        <TableColumn fx:id="colStart" prefWidth="90.0" text="Startzeit" />
                        <TableColumn fx:id="colEnde" prefWidth="90.0" text="Endzeit" />
                        <TableColumn fx:id="colDauer" prefWidth="100.0" text="Dauer" />
                        <TableColumn fx:id="colBeschreibung" prefWidth="250.0" text="Beschreibung" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    
    <!-- Rechter Bereich: Tagesübersichten (ListView mit Custom Cells) -->
    <right>
        <VBox spacing="10.0" style="-fx-background-color: #f9f9f9; -fx-border-color: #dcdcdc; -fx-border-width: 0 0 0 1;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label text="Tagesübersicht">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <ListView fx:id="lstArbeitstage" prefWidth="180.0" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </right>
</BorderPane>
